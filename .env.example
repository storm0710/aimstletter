# Required when posting to Slack.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional OpenAI. When omitted, the digest uses a deterministic rule-based summary.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini

# Optional Azure OpenAI. If AZURE_OPENAI_API_KEY is set, it takes priority over OPENAI_API_KEY.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Optional tuning.
DIGEST_LOOKBACK_DAYS=7
DIGEST_MAX_ITEMS=10
DIGEST_CHANNEL_LABEL=AI마스터

# Optional Naver Blog publishing.
# NAVER_BLOG_API_PASSWORD is the Blog Writing API password, not your normal login password.
NAVER_BLOG_ID=your-blog-id
NAVER_BLOG_USERNAME=your-naver-id
NAVER_BLOG_API_PASSWORD=your-blog-api-password

# Optional GitHub Pages visitor analytics.
# Supported providers: ga4, goatcounter, plausible.
SITE_ANALYTICS_PROVIDER=
SITE_ANALYTICS_ID=
SITE_ANALYTICS_DOMAIN=
